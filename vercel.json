{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/fitness-app build",
  "outputDirectory": "artifacts/fitness-app/dist/public",
  "rewrites": [
    {
      "source": "/((?!api(?:/|$))(?!.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
